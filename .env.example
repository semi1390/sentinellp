# ============================================================
# SentinelLP — Environment Configuration
# Copy this to .env and fill in real values.
# NEVER commit .env to git.
# ============================================================

# --- Ethereum RPC (read-only, for position monitoring) ---
# Free tier at https://alchemy.com or https://infura.io
ETH_RPC_URL=https://eth-mainnet.g.alchemy.com/v2/YOUR_ALCHEMY_KEY

# --- Wallet to monitor ---
# This is the wallet that HOLDS your Uniswap LP positions.
# KeeperHub's Turnkey wallet is what EXECUTES the transactions.
# These can be the same address if you fund the KeeperHub wallet and use it for LP.
WALLET_ADDRESS=0xYOUR_WALLET_ADDRESS

# --- KeeperHub ---
# 1. Sign up at https://app.keeperhub.com
# 2. Go to Settings > API Keys > Organisation tab > Create New Key
# 3. Copy the kh_ prefixed key below (shown once only)
KEEPERHUB_API_KEY=

# 4. Your KeeperHub Turnkey wallet ID (this wallet signs transactions)
#    Run: npm run get-wallet  to fetch it automatically
#    Or:  Settings > Integrations in the KeeperHub dashboard
KEEPERHUB_WALLET_ID=your_wallet_integration_id_here

# --- Claude / Anthropic (the agent brain) ---
# Get your key at https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-your-key-here

# --- Network ---
# "11155111" = Sepolia testnet (FREE — start here)
# "1"        = Ethereum mainnet (real money — switch for competition)
TARGET_NETWORK=11155111

# --- Uniswap v3 Contract Addresses ---
# These are the official mainnet addresses. Leave as-is for mainnet.
# For Sepolia you'll need a Uniswap v3 deployment or a fork.
UNISWAP_POSITION_MANAGER=0xC36442b4a4522E871399CD717aBDD847Ab11FE88
UNISWAP_FACTORY=0x1F98431c8aD98523631AE4a59f267346ea31F984

# --- Agent Behaviour ---
POLL_INTERVAL_MINUTES=5
OUT_OF_RANGE_THRESHOLD_POLLS=2
MIN_POSITION_VALUE_USD=500

# --- Logging ---
LOG_LEVEL=info
LOG_FILE=logs/sentinellp.log
